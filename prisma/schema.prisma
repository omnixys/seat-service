/// ----------------------------------------------------------------------
/// Prisma Schema – Omnixys Seat Service
/// Author: Caleb Gyamfi – Omnixys Technologies
///
/// THIS SERVICE OWNS:
/// - Sections
/// - Tables
/// - Seats
/// - Seat Assignments
/// - Seat Layout Metadata
///
/// THIS SERVICE DOES NOT OWN:
/// - Event information
///   → eventId is a foreign reference by ID only
/// ----------------------------------------------------------------------

generator client {
  provider = "prisma-client"
  output   = "../src/prisma/generated"
}

datasource db {
  provider = "postgresql"
}

//
// SECTION
//

model Section {
  id      String @id @default(uuid()) @map("id") @db.Uuid
  eventId String @map("event_id") @db.Uuid

  name  String
  order Int

  capacity Int?

  shape SectionShape @default(RECTANGLE)

  x Float @default(0)
  y Float @default(0)

  width  Float?
  height Float?

  rotation Float? @default(0)

  meta Json?

  tables Table[]
  seats  Seat[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@unique([eventId, name])
  @@index([eventId])
  @@map("section")
}

//
// TABLE
//

model Table {
  id        String @id @default(uuid()) @db.Uuid
  eventId   String @map("event_id") @db.Uuid
  sectionId String @map("section_id") @db.Uuid

  name  String
  order Int

  capacity Int?

  shape TableShape @default(ROUND)

  x Float @default(0)
  y Float @default(0)

  rotation Float? @default(0)

  meta Json?

  seats Seat[]

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@unique([sectionId, name])
  @@index([eventId])
  @@index([sectionId])
  @@index([eventId, sectionId])
  @@map("table")
}

//
// SEAT
//

model Seat {
  id     String     @id @default(uuid()) @map("id") @db.Uuid
  status SeatStatus @default(AVAILABLE)

  eventId   String  @map("event_id") @db.Uuid
  sectionId String  @map("section_id") @db.Uuid
  tableId   String? @map("table_id") @db.Uuid

  number Int?
  label  String?
  note   String?

  seatType SeatType? @map("seat_type")

  shape SeatShape @default(CIRCLE)

  x Float?
  y Float?

  width  Float?
  height Float?
  radius Float?

  rotation Float?

  zIndex Int?    @default(0) @map("z_index")
  locked Boolean @default(false)
  hidden Boolean @default(false)

  guestId      String? @map("guest_id") @db.Uuid
  invitationId String? @map("invitation_id") @db.Uuid

  meta Json?

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  table   Table?  @relation(fields: [tableId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@unique([eventId, invitationId])
  @@unique([eventId, guestId])
  @@index([eventId])
  @@index([sectionId])
  @@index([tableId])
  @@index([guestId])
  @@index([eventId, sectionId])
  @@index([eventId, tableId])
  @@map("seat")
}

//
// SEAT ASSIGNMENT HISTORY
//

model SeatAssignmentLog {
  id           String  @id @default(uuid()) @db.Uuid
  eventId      String  @map("event_id") @db.Uuid
  seatId       String  @map("seat_id") @db.Uuid
  guestId      String? @map("guest_id") @db.Uuid
  invitationId String? @map("invitation_id") @db.Uuid

  action SeatAssignmentAction

  data Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([eventId])
  @@index([seatId])
  @@map("seat_assignment_log")
}

//
// LAYOUT VERSION SNAPSHOT
//

model LayoutVersion {
  id      String @id @default(uuid()) @db.Uuid
  eventId String @map("event_id") @db.Uuid

  version BigInt
  label   String?

  data Json

  patch        Json?
  inversePatch Json? @map("inverse_patch")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([eventId, version])
  @@index([eventId])
  @@map("layout_version")
}

//
// LAYOUT CHANGE LOG
//

model LayoutChangeLog {
  id      String @id @default(uuid()) @db.Uuid
  eventId String @map("event_id") @db.Uuid

  actorId String @map("actor_id") @db.Uuid

  type LayoutChangeType

  payload Json

  createdAt DateTime @default(now()) @map("created_at")

  @@index([eventId])
  @@map("layout_change_log")
}

//
// EVENT ROLE PROJECTION
//

model EventRoleProjection {
  id      String         @id @default(uuid()) @map("id") @db.Uuid
  eventId String         @map("event_id") @db.Uuid
  userId  String         @map("user_id") @db.Uuid
  role    EventRoleType  @map("role")
  updatedAt DateTime?    @updatedAt @map("updated_at")

  @@unique([eventId, userId], name: "uq_event_role_projection")
  @@index([eventId], name: "idx_event_role_projection_event")
  @@map("event_role_projection")
}

enum EventRoleType {
  ADMIN
  SECURITY
  GUEST

  @@map("event_role_type")
}

//
// ENUMS
//

enum SeatStatus {
  AVAILABLE
  RESERVED
  ASSIGNED
  BLOCKED

  @@map("seat_status")
}

enum SeatType {
  STANDARD
  VIP
  STAFF
  STANDING
  CHILD
  RESERVED

  @@map("seat_type")
}

enum SeatShape {
  CIRCLE
  SQUARE
  RECTANGLE

  @@map("seat_shape")
}

enum TableShape {
  ROUND
  RECTANGLE
  OVAL
  ROW

  @@map("table_shape")
}

enum SectionShape {
  RECTANGLE
  CIRCLE
  POLYGON

  @@map("section_shape")
}

enum SeatAssignmentAction {
  ASSIGNED
  UNASSIGNED
  MOVED

  @@map("seat_assignment_action")
}

enum LayoutChangeType {
  SECTION_CREATE
  SECTION_UPDATE
  SECTION_DELETE
  SECTION_MOVED
  SECTION_RENAME
  SECTION_CLONED

  TABLE_CREATE
  TABLE_UPDATE
  TABLE_DELETE
  TABLE_MOVED
  TABLE_RENAME
  TABLE_DUPLICATED

  SEAT_CREATE
  SEAT_UPDATE
  SEAT_DELETE
  SEAT_ASSIGNED
  SEAT_UNASSIGNED

  SEAT_MOVED
  SEAT_ASSIGN

  AUTO_GENERATE_GEOMETRY_V4
  LAYOUT_VERSION_SAVED

  @@map("layout_change_type")
}
