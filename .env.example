NODE_ENV=development
SERVICE=seat-service
PORT=4000
SCHEMA_TARGET=true
COOKIE_SECRET=replace-with-at-least-32-random-characters

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/seat
KAFKA_BROKER=localhost:9092
VALKEY_URL=valkey://localhost:6380
VALKEY_PASSWORD=

KC_URL=http://localhost:18080/auth
KC_REALM=camunda-platform
KC_CLIENT_ID=camunda-identity
KC_CLIENT_SECRET=
ENCRYPTION_KEY=replace-with-service-encryption-key
PC_JWE_KEY=replace-with-pending-contact-key

TEMPO_URI=http://localhost:4318/v1/traces
LOG_LEVEL=debug
LOG_PRETTY=true

# Optional external readiness checks
KEYCLOAK_HEALTH_URL=
TEMPO_HEALTH_URL=
PROMETHEUS_HEALTH_URL=
